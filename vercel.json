{
  "buildCommand": "pnpm build",
  "outputDirectory": "dist/public",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/sync-pedidos",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/sync-produtos",
      "schedule": "0 11 * * *"
    }
  ]
}
