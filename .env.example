# ─── Banco de dados (PostgreSQL) ──────────────────────────────────────────────
DATABASE_URL=

# ─── Autenticação ─────────────────────────────────────────────────────────────
VITE_AUTH_MODE=oauth
VITE_APP_ID=
JWT_SECRET=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
LOCAL_AUTH_NAME=Administrador
LOCAL_AUTH_EMAIL=admin@boat.local
ADMIN_PASSWORD=

# ─── Integração Tiny/Olist ────────────────────────────────────────────────────
# Mesmo token configurado na Vercel. Necessário para a sincronização de pedidos
# e para o CRM de recompra (enriquecimento de telefone e write-back de contato).
OLIST_API_TOKEN=

# Write-back do CRM no Olist. Fica SEMPRE ativo por padrão: ao editar telefone/
# e-mail de um cliente no CRM, o cadastro é atualizado no Tiny (contato.alterar/
# contato.incluir), além do update local imediato. Defina explicitamente como
# "false" para desligar (grava só no banco local).
OLIST_WRITEBACK_ENABLED=true

# ─── LLM (insights) ───────────────────────────────────────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
