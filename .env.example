# ─── Banco de dados (PostgreSQL) ──────────────────────────────────────────────
DATABASE_URL=

# ─── Autenticação ─────────────────────────────────────────────────────────────
VITE_AUTH_MODE=oauth
VITE_APP_ID=
JWT_SECRET=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
LOCAL_AUTH_NAME=Administrador
LOCAL_AUTH_EMAIL=admin@boat.local
ADMIN_PASSWORD=

# ─── Integração Tiny/Olist ────────────────────────────────────────────────────
# Mesmo token configurado na Vercel. Necessário para a sincronização de pedidos
# e para o CRM de recompra (enriquecimento de telefone e write-back de contato).
OLIST_API_TOKEN=

# Write-back do CRM no Olist. Quando "false" (padrão), a edição de telefone/e-mail
# do cliente é gravada apenas no banco local (optimistic update) e NÃO altera o
# cadastro no Tiny. Defina como "true" para efetivamente enviar contato.alterar/
# contato.incluir à API de produção.
OLIST_WRITEBACK_ENABLED=false

# ─── LLM (insights) ───────────────────────────────────────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
